{
  "name": "almost-there",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vite build --configLoader native",
    "lint": "eslint .",
    "preview": "vite preview --configLoader native",
    "test": "node --test src/utils/normalizers.test.js",
    "functions:install": "npm install --prefix functions",
    "predeploy": "npm run build",
    "deploy": "npm run predeploy && firebase deploy --only hosting",
